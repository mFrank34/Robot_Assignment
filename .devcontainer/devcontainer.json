{
  "name": "ROS2 Humble Dev",
  "build": {
    "dockerfile": "Container"
  },
  "workspaceMount": "source=/home/frank/Projects/Robot_Assignment,target=/workspace,type=bind,Z",
  "workspaceFolder": "/workspace",
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined",
    "--security-opt=label=disable",
    "--userns=keep-id",
    "-e",
    "DISPLAY=${env:DISPLAY}",
    "-e",
    "XAUTHORITY=/tmp/.Xauthority",
    "-v",
    "/tmp/.X11-unix:/tmp/.X11-unix",
    "-v",
    "/home/frank/.Xauthority:/tmp/.Xauthority:ro"
  ],
  "remoteUser": "root",
  "containerUser": "root",
  "remoteEnv": {
    "HOME": "/workspace",
    "GIT_CONFIG_GLOBAL": "/workspace/.gitconfig",
    "ROS_DISTRO": "humble",
    "PYTHONPATH": "/opt/ros/humble/lib/python3.10/site-packages:/opt/ros/humble/local/lib/python3.10/dist-packages"
  },
  "postCreateCommand": "bash -c 'echo \"source /opt/ros/humble/setup.bash\" >> ~/.bashrc'"
}