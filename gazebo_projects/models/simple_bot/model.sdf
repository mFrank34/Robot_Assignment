<sdf version="1.7">
    <model name="square_bot">
        <pose>0 0 0 0 0 0</pose>

        <link name="chassis">
            <pose relative_to='__model__'>0 0 0.15 0 0 0</pose>
            <inertial>
                <mass>1.5</mass>
                <inertia>
                    <ixx>0.1</ixx>
                    <iyy>0.1</iyy>
                    <izz>0.1</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <box>
                        <size>0.6 0.5 0.1</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0 0 1 1</ambient>
                    <diffuse>0 0 1 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <box>
                        <size>0.6 0.5 0.1</size>
                    </box>
                </geometry>
            </collision>
        </link>

        <link name="front_lidar_link">
            <pose relative_to="chassis">0.3 0 0.08 0 0 0</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <iyy>0.001</iyy>
                    <izz>0.001</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.04</radius>
                        <length>0.06</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.2 0.2 0.2 1</ambient>
                    <diffuse>0.2 0.2 0.2 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>0.04</radius>
                        <length>0.06</length>
                    </cylinder>
                </geometry>
            </collision>
            <sensor name="front_lidar" type="gpu_lidar">
                <pose>0 0 0 0 0 0</pose>
                <topic>front_lidar/scan</topic>
                <update_rate>10</update_rate>
                <lidar>
                    <scan>
                        <horizontal>
                            <samples>360</samples>
                            <resolution>1</resolution>
                            <min_angle>-1.5707963</min_angle>
                            <max_angle>1.5707963</max_angle>
                        </horizontal>
                    </scan>
                    <range>
                        <min>0.1</min>
                        <max>10.0</max>
                        <resolution>0.01</resolution>
                    </range>
                </lidar>
                <visualize>true</visualize>
            </sensor>
        </link>

        <joint name="front_lidar_joint" type="fixed">
            <parent>chassis</parent>
            <child>front_lidar_link</child>
        </joint>

        <link name="camera_pan_link">
            <pose relative_to="chassis">0.28 0 0.1 0 0 0</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.0001</ixx>
                    <iyy>0.0001</iyy>
                    <izz>0.0001</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.03</radius>
                        <length>0.04</length>
                    </cylinder>
                </geometry>
            </visual>
            <self_collide>false</self_collide>
        </link>

        <joint name="camera_pan_joint" type="revolute">
            <parent>chassis</parent>
            <child>camera_pan_link</child>
            <axis>
                <xyz>0 0 1</xyz>
                <limit>
                    <lower>-1.5708</lower>
                    <upper>1.5708</upper>
                </limit>
                <dynamics>
                    <damping>0.1</damping>
                </dynamics>
            </axis>
        </joint>

        <link name="camera_tilt_link">
            <pose relative_to="camera_pan_link">0 0 0.05 0 0 0</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.0001</ixx>
                    <iyy>0.0001</iyy>
                    <izz>0.0001</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <box>
                        <size>0.05 0.08 0.05</size>
                    </box>
                </geometry>
            </visual>
            <self_collide>false</self_collide>

            <sensor name="camera" type="camera">
                <pose>0.025 0 0 0 0 0</pose>
                <topic>camera/image</topic>
                <update_rate>30</update_rate>
                <camera>
                    <horizontal_fov>1.047</horizontal_fov>
                    <image>
                        <width>640</width>
                        <height>480</height>
                        <format>R8G8B8</format>
                    </image>
                    <clip>
                        <near>0.1</near>
                        <far>100</far>
                    </clip>
                </camera>
                <visualize>true</visualize>
            </sensor>
        </link>

        <joint name="camera_tilt_joint" type="revolute">
            <parent>camera_pan_link</parent>
            <child>camera_tilt_link</child>
            <axis>
                <xyz>0 1 0</xyz>
                <limit>
                    <lower>-0.5236</lower>
                    <upper>0.5236</upper>
                </limit>
                <dynamics>
                    <damping>0.1</damping>
                </dynamics>
            </axis>
        </joint>

        <link name="front_left_wheel">
            <pose relative_to="chassis">0.25 0.3 -0.05 0 0 0</pose>
            <inertial>
                <mass>0.3</mass>
                <inertia>
                    <ixx>0.01</ixx>
                    <iyy>0.01</iyy>
                    <izz>0.02</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
            </visual>
            <collision name="collision">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
            </collision>
        </link>

        <link name="front_right_wheel">
            <pose relative_to="chassis">0.25 -0.3 -0.05 0 0 0</pose>
            <inertial>
                <mass>0.3</mass>
                <inertia>
                    <ixx>0.01</ixx>
                    <iyy>0.01</iyy>
                    <izz>0.02</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
            </visual>
            <collision name="collision">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
            </collision>
        </link>

        <link name="rear_left_wheel">
            <pose relative_to="chassis">-0.25 0.3 -0.05 0 0 0</pose>
            <collision name="collision">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0</mu>
                            <mu2>0</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
            <visual name="visual">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
            </visual>
        </link>

        <link name="rear_right_wheel">
            <pose relative_to="chassis">-0.25 -0.3 -0.05 0 0 0</pose>
            <collision name="collision">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0</mu>
                            <mu2>0</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
            <visual name="visual">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
            </visual>
        </link>

        <joint name="front_left_joint" type="revolute">
            <parent>chassis</parent>
            <child>front_left_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
            </axis>
        </joint>

        <joint name="front_right_joint" type="revolute">
            <parent>chassis</parent>
            <child>front_right_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
            </axis>
        </joint>

        <joint name="rear_left_joint" type="revolute">
            <parent>chassis</parent>
            <child>rear_left_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
            </axis>
        </joint>

        <joint name="rear_right_joint" type="revolute">
            <parent>chassis</parent>
            <child>rear_right_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
            </axis>
        </joint>

        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>front_left_joint</left_joint>
            <right_joint>front_right_joint</right_joint>
            <wheel_separation>0.6</wheel_separation>
            <wheel_radius>0.1</wheel_radius>
            <topic>cmd_vel</topic>
        </plugin>

        <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
            <joint_name>camera_pan_joint</joint_name>
            <topic>camera_pan</topic>
        </plugin>

        <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
            <joint_name>camera_tilt_joint</joint_name>
            <topic>camera_tilt</topic>
        </plugin>

        <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>
    </model>
</sdf>