                            <size>0.2 10 1</size>
                        </box>
                    </geometry>
                    <material>
                        <ambient>1 0.8 0 1</ambient>
                        <diffuse>1 0.8 0 1</diffuse>
                    </material>
                </visual>
            </link>
        </model>

        <model name="inner_wall_north">
            <static>true</static>
            <pose>0 2 0.5 0 0 0</pose>
            <link name="link">
